{
  "name": "@fairux/ast",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AST adapter for FairUX Linter: parses JSX/TSX source into a @fairux/core UiDocument (TypeScript compiler API).",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fairux/core": "workspace:*",
    "typescript": "~6.0.0"
  },
  "devDependencies": {
    "@fairux/rules": "workspace:*"
  }
}
