{
  "name": "@fairux/figma",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Figma adapter for FairUX Linter: converts Figma REST API JSON into a @fairux/core UiDocument.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fairux/core": "workspace:*"
  },
  "devDependencies": {
    "@fairux/rules": "workspace:*"
  }
}
