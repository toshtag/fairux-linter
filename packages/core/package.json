{
  "name": "@fairux/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Runtime-agnostic, browser-safe core for FairUX Linter: types, scan pipeline, fingerprinting, traversal/semantics helpers.",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
