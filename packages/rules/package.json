{
  "name": "@fairux/rules",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "FairUX rule set: browser-safe, explainable UX risk-signal rules built on @fairux/core.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fairux/core": "workspace:*"
  },
  "devDependencies": {
    "@fairux/html": "workspace:*"
  }
}
