{
  "name": "@fairux/report",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Reporters for FairUX Linter: render a FairUxReport as JSON (public API) or Markdown.",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fairux/core": "workspace:*"
  }
}
