{
  "name": "fairux-linter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Rule-based UX linter that detects UI patterns which may distort user decision-making.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test:built": "vitest run --passWithNoTests",
    "test": "pnpm --filter \"@fairux/cli...\" build && pnpm test:built",
    "test:watch": "vitest",
    "test:cli-security": "pnpm --filter \"@fairux/cli...\" build && vitest run apps/cli/test/cli-security.test.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check:runtime-safety": "node scripts/check-runtime-safety.mjs",
    "verify": "pnpm lint && pnpm build && pnpm typecheck && pnpm test:built && pnpm check:runtime-safety",
    "fairux": "node apps/cli/dist/index.js",
    "scan:example": "node apps/cli/dist/index.js scan examples/checkout.html",
    "pack:smoke": "node apps/cli/scripts/pack-smoke-test.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
