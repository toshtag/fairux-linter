{
  "name": "fairux-linter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Rule-based UX linter that detects UI patterns which may distort user decision-making.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check:runtime-safety": "node scripts/check-runtime-safety.mjs",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm check:runtime-safety"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
